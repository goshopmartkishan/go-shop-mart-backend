# ============================================
# Go Shop Mart - Backend Environment Variables
# Copy this file as .env.local and fill in your values
# ============================================

# License Key Encryption Secret (KEEP THIS SECRET & UNIQUE!)
LICENSE_SECRET_KEY=go-shop-mart-secret-key-2026

# Admin Panel Password
ADMIN_PASSWORD=YourStrongPasswordHere

# Vercel KV (Redis) - Get from Vercel Dashboard > Storage > KV
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Supabase (if using Supabase for data)
SUPABASE_URL=
SUPABASE_KEY=
